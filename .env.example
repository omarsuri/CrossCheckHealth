# App
NEXT_PUBLIC_API_URL=your_public_api_url

# Supabase public client values
# These are safe to expose to the browser when using Supabase RLS correctly.
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase server-only value
# Never expose this in client components or browser code.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
